# ──────────────────────────────────────────────
#  Teams Watcher — Configuration
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Azure AD App Registration (portal.azure.com -> App registrations)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Your manager's info (set at least one)
MANAGER_NAME=Jane Doe
MANAGER_EMAIL=jane.doe@company.com

# Twilio credentials (twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
MY_PHONE_NUMBER=+1XXXXXXXXXX

# How often to poll for new messages (seconds)
POLL_INTERVAL=15

# Minimum seconds between phone calls (avoids spam-calling)
CALL_COOLDOWN=120
